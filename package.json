{
  "name": "mcp",
  "version": "1.0.0",
  "description": "MCP Weather Data Fetcher Server",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "tsx server.ts",
    "dev": "tsx server.ts",
    "api": "tsx api/index.ts",
    "client": "cd client && npm run dev",
    "demo": "concurrently \"npm run api\" \"npm run client\"",
    "inspector": "npx @modelcontextprotocol/inspector npx tsx ./server.ts"
  },
  "keywords": ["mcp", "weather", "modelcontextprotocol"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  }
}
